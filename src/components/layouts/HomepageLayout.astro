---
import AnimatedSVG from "../AnimatedSVG2.astro";
import Nav from "../Nav.astro";
import OffTheKeyboard from "../OffTheKeyboard.astro";
import HeroGrid from "../HeroGrid.astro";

export interface Props {
  xEyes?: boolean;
}

const { xEyes = false } = Astro.props;
---

<!-- Homepage Layout: Two-column with animated SVG -->
<div class="flex justify-center min-h-screen p-4 sm:p-6 lg:p-8">
  <div class="w-full max-w-6xl mx-auto relative">
    <div class="hero-band">
      <HeroGrid />
      <div class="hero-band__content">
        <Nav />

        <div class="grid grid-cols-1 lg:grid-cols-2">
          <div
            class="p-4 sm:p-12 flex justify-center lg:sticky lg:top-12 lg:h-fit"
          >
            <AnimatedSVG xEyes={xEyes} />
          </div>

          <div class="p-4 sm:p-12 flex flex-col justify-center">
            <div
              class="whoami font-mono text-sm text-violet-600 dark:text-violet-400 tracking-wide mb-3"
            >
              $ whoami
            </div>
            <h1
              class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-gray-800 dark:text-white tracking-tight"
            >
              Luke DeWitt
            </h1>
            <slot />
          </div>
        </div>
      </div>
    </div>

    <OffTheKeyboard />
  </div>
</div>

<style>
  /* Hero band anchors the absolute HeroGrid canvas behind nav + hero.
     It breaks out of the centered max-width column so the grid spans the
     full viewport width, while padding-inline keeps the content aligned
     to the original column. (The canvas is absolute inset:0, so it fills
     the full band width and ignores this padding.) */
  .hero-band {
    position: relative;
    margin-inline: calc(50% - 50vw);
    padding-inline: calc(50vw - 50%);
    /* Pull up through the page's top padding (outer p-4 / sm:p-6 / lg:p-8)
       so the grid reaches the very top of the viewport. The content below
       gets an equal padding-top, so the nav stays exactly where it was. */
    margin-top: -1rem;
    /* Extend the canvas down into the OffTheKeyboard section's top margin
       (mt-8 / sm:mt-12) so the grid reaches its border. padding-bottom grows
       the canvas; the equal negative margin-bottom keeps the layout footprint
       unchanged, so the section below stays put. */
    padding-bottom: 2rem;
    margin-bottom: -2rem;
  }
  .hero-band__content {
    position: relative;
    z-index: 1;
    padding-top: 1rem;
  }
  @media (min-width: 640px) {
    .hero-band {
      margin-top: -1.5rem;
      padding-bottom: 3rem;
      margin-bottom: -3rem;
    }
    .hero-band__content {
      padding-top: 1.5rem;
    }
  }
  @media (min-width: 1024px) {
    .hero-band {
      margin-top: -2rem;
    }
    .hero-band__content {
      padding-top: 2rem;
    }
  }

  .whoami {
    font-family: var(--font-mono-jetbrains);
  }
</style>